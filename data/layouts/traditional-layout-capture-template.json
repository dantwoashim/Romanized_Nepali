{
  "schemaVersion": 1,
  "layoutFamily": "traditional-nepali",
  "status": "capture-template",
  "implementationAllowed": false,
  "purpose": "Manual capture checklist for LTK-compatible and standard Traditional layouts. This file intentionally contains no Unicode outputs.",
  "requiredModifierStates": [
    { "id": "normal", "shift": false, "altGraph": false },
    { "id": "shift", "shift": true, "altGraph": false },
    { "id": "altgr", "shift": false, "altGraph": true },
    { "id": "shift-altgr", "shift": true, "altGraph": true }
  ],
  "requiredCodes": [
    "Backquote",
    "Digit1",
    "Digit2",
    "Digit3",
    "Digit4",
    "Digit5",
    "Digit6",
    "Digit7",
    "Digit8",
    "Digit9",
    "Digit0",
    "Minus",
    "Equal",
    "KeyQ",
    "KeyW",
    "KeyE",
    "KeyR",
    "KeyT",
    "KeyY",
    "KeyU",
    "KeyI",
    "KeyO",
    "KeyP",
    "BracketLeft",
    "BracketRight",
    "Backslash",
    "KeyA",
    "KeyS",
    "KeyD",
    "KeyF",
    "KeyG",
    "KeyH",
    "KeyJ",
    "KeyK",
    "KeyL",
    "Semicolon",
    "Quote",
    "KeyZ",
    "KeyX",
    "KeyC",
    "KeyV",
    "KeyB",
    "KeyN",
    "KeyM",
    "Comma",
    "Period",
    "Slash",
    "Space"
  ],
  "captureFields": [
    "layoutId",
    "code",
    "key",
    "modifierState",
    "observedOutput",
    "unicodeCodePoints",
    "source",
    "sourceUrl",
    "capturedBy",
    "capturedAt",
    "verifiedBy",
    "verifiedAt",
    "licenseOrPermissionNote",
    "notes"
  ],
  "blockedUntil": [
    "Every required code is captured for normal and Shift.",
    "AltGr/Option and Shift+AltGr/Option are captured or explicitly marked not applicable.",
    "Halanta, matra ordering, punctuation, digits, and conjunct-relevant sequences have fixtures.",
    "At least one Traditional typist validates the LTK-compatible layout.",
    "Source/provenance and license/permission notes are complete."
  ]
}
