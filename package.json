{
  "name": "lekh-assistant",
  "private": true,
  "version": "0.1.0-week1",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsx scripts/write-service-worker.ts",
    "test": "vitest run --pool=forks",
    "test:watch": "vitest --pool=forks",
    "typecheck": "tsc -b --noEmit",
    "verify": "npm run typecheck && npm run test && npm run build && npm run check:privacy && npm run check:offline && npm run check:runtime-data && npm run check:user-data && npm run benchmark:proofread && npm run benchmark:competitor && npm run verify:engine",
    "verify:engine": "npm run check:engine-local && npm run check:engine-no-dom && npm run benchmark:protected",
    "check:privacy": "tsx scripts/check-no-text-telemetry.ts",
    "check:engine-local": "tsx scripts/check-engine-local-first.ts",
    "check:engine-no-dom": "tsx scripts/check-engine-no-dom.ts",
    "check:user-data": "tsx scripts/check-user-data-safety.ts",
    "check:offline": "tsx scripts/check-offline-build.ts",
    "check:runtime-data": "tsx scripts/check-no-benchmark-data-in-runtime.ts",
    "generate:fixtures": "tsx scripts/generate-romanized-fixtures.ts && tsx scripts/generate-preeti-fixtures.ts",
    "generate:fixtures:romanized": "tsx scripts/generate-romanized-fixtures.ts",
    "generate:fixtures:preeti": "tsx scripts/generate-preeti-fixtures.ts",
    "generate:wordlist": "tsx scripts/expand-wordlist.ts",
    "lexicon:rank-hunspell": "tsx scripts/rank-hunspell-by-frequency.ts",
    "lexicon:merge": "tsx scripts/merge-lexicon-expansion.ts",
    "rank:hunspell": "tsx scripts/rank-hunspell-by-frequency.ts",
    "ingest:preeti-real": "tsx scripts/ingest-real-preeti-fixtures.ts",
    "dictionary:review": "tsx scripts/generate-dictionary-review.ts",
    "report:quality": "vite-node scripts/evaluate-quality.ts",
    "report:preeti": "vite-node scripts/evaluate-preeti-quality.ts",
    "import:frequency": "tsx scripts/import-frequency-source.ts",
    "benchmark:fixtures": "tsx scripts/generate-benchmark-fixtures.ts",
    "benchmark:preeti": "vite-node scripts/benchmark-preeti.ts",
    "benchmark:romanized": "vite-node scripts/benchmark-romanized.ts",
    "benchmark:protected": "vite-node scripts/benchmark-protected-spans.ts",
    "benchmark:proofread": "vite-node scripts/benchmark-proofread.ts",
    "benchmark:competitor": "vite-node scripts/benchmark-competitor-probes.ts",
    "bench:perf": "vite-node scripts/bench-perf.ts",
    "scorecard:engine": "vite-node scripts/generate-engine-scorecard.ts",
    "benchmark": "npm run benchmark:fixtures && vite-node scripts/benchmark-summary.ts"
  },
  "dependencies": {
    "@nepalibhasha/converter": "^0.1.0",
    "dictionary-ne": "^2.0.0",
    "lucide-react": "^0.468.0",
    "nspell": "^2.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.1.2",
    "jsdom": "^29.1.1",
    "rollup": "npm:@rollup/wasm-node@^4.60.4",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  }
}
