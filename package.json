{
  "name": "lekh-assistant",
  "private": true,
  "version": "0.1.0-week1",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsx scripts/write-service-worker.ts",
    "test": "vitest run --pool=forks --minWorkers=1 --maxWorkers=2",
    "test:unit": "vitest run --pool=forks --minWorkers=1 --maxWorkers=2",
    "test:dictionary": "vitest run src/core/dictionary/dictionary.test.ts --pool=forks --minWorkers=1 --maxWorkers=1",
    "test:watch": "vitest --pool=forks --minWorkers=1 --maxWorkers=2",
    "typecheck": "tsc -b --noEmit",
    "verify": "npm run typecheck && npm run test && npm run build && npm run check:privacy && npm run check:offline && npm run check:runtime-data && npm run check:user-data && npm run audit:traditional-layout && npm run check:benchmark-disjointness && npm run benchmark:typing-session && npm run benchmark:romanized:smoke && npm run benchmark:romanized:self:smoke && npm run benchmark:proofread && npm run benchmark:competitor && npm run bench:perf:smoke && npm run scorecard:engine && npm run verify:engine",
    "verify:full": "npm run typecheck && npm run test && npm run build && npm run check:privacy && npm run check:offline && npm run check:runtime-data && npm run check:user-data && npm run audit:traditional-layout && npm run check:benchmark-disjointness && npm run benchmark && npm run benchmark:mixed-span-mutations && npm run benchmark:typing-session && npm run bench:perf:full && npm run benchmark:proofread && npm run benchmark:competitor && npm run scorecard:engine && npm run verify:engine:full",
    "verify:engine": "npm run check:engine-local && npm run check:engine-no-dom && npm run benchmark:protected && npm run benchmark:romanized:self:smoke",
    "verify:engine:full": "npm run check:engine-local && npm run check:engine-no-dom && npm run benchmark:protected && npm run alias:romanized && npm run check:alias-collisions && npm run benchmark:romanized:self",
    "check:privacy": "tsx scripts/check-no-text-telemetry.ts",
    "check:engine-local": "tsx scripts/check-engine-local-first.ts",
    "check:engine-no-dom": "tsx scripts/check-engine-no-dom.ts",
    "check:user-data": "tsx scripts/check-user-data-safety.ts",
    "check:offline": "tsx scripts/check-offline-build.ts",
    "check:runtime-data": "tsx scripts/check-no-benchmark-data-in-runtime.ts",
    "check:benchmark-disjointness": "tsx scripts/check-benchmark-disjointness.ts",
    "audit:preeti-source": "LEKH_SCRIPT=audit-preeti-source LEKH_BENCHMARK_CLI=1 vite-node scripts/audit-preeti-source-fixtures.ts",
    "audit:traditional-layout": "tsx scripts/validate-traditional-layout-audit.ts",
    "inspect:legacy-font": "LEKH_SCRIPT=inspect-legacy-font LEKH_BENCHMARK_CLI=1 vite-node scripts/inspect-legacy-font.ts",
    "generate:fixtures": "tsx scripts/generate-romanized-fixtures.ts && tsx scripts/generate-preeti-fixtures.ts",
    "generate:fixtures:romanized": "tsx scripts/generate-romanized-fixtures.ts",
    "generate:fixtures:preeti": "tsx scripts/generate-preeti-fixtures.ts",
    "generate:wordlist": "tsx scripts/expand-wordlist.ts",
    "lexicon:rank-hunspell": "tsx scripts/rank-hunspell-by-frequency.ts",
    "lexicon:merge": "tsx scripts/merge-lexicon-expansion.ts",
    "rank:hunspell": "tsx scripts/rank-hunspell-by-frequency.ts",
    "ingest:preeti-real": "tsx scripts/ingest-real-preeti-fixtures.ts",
    "dictionary:review": "tsx scripts/generate-dictionary-review.ts",
    "report:quality": "vite-node scripts/evaluate-quality.ts",
    "report:preeti": "vite-node scripts/evaluate-preeti-quality.ts",
    "import:frequency": "tsx scripts/import-frequency-source.ts",
    "benchmark:fixtures": "tsx scripts/generate-benchmark-fixtures.ts",
    "benchmark:preeti": "LEKH_BENCHMARK_CLI=1 vite-node scripts/benchmark-preeti.ts",
    "generate:preeti-map-fixtures": "LEKH_SCRIPT=generate-preeti-map-fixtures LEKH_BENCHMARK_CLI=1 vite-node scripts/generate-preeti-map-fixtures.ts",
    "generate:preeti-boundary-fixtures": "LEKH_SCRIPT=generate-preeti-boundary-fixtures LEKH_BENCHMARK_CLI=1 vite-node scripts/generate-preeti-boundary-fixtures.ts",
    "generate:preeti-roundtrip-fixtures": "LEKH_SCRIPT=generate-preeti-roundtrip-fixtures LEKH_BENCHMARK_CLI=1 vite-node scripts/generate-preeti-roundtrip-fixtures.ts",
    "benchmark:preeti:fuzz": "LEKH_SCRIPT=benchmark-preeti-fuzz LEKH_BENCHMARK_CLI=1 vite-node scripts/benchmark-preeti-fuzz.ts",
    "benchmark:preeti:roundtrip": "LEKH_SCRIPT=benchmark-preeti-roundtrip LEKH_BENCHMARK_CLI=1 vite-node scripts/benchmark-preeti-roundtrip.ts",
    "alias:romanized": "LEKH_SCRIPT=alias-romanized LEKH_BENCHMARK_CLI=1 vite-node scripts/generate-romanized-alias-factory.ts",
    "generate:romanized-aliases": "npm run alias:romanized",
    "check:alias-collisions": "LEKH_SCRIPT=alias-collisions LEKH_BENCHMARK_CLI=1 vite-node scripts/report-romanized-alias-collisions.ts",
    "report:alias-collisions": "npm run check:alias-collisions",
    "benchmark:romanized": "LEKH_BENCHMARK_CLI=1 vite-node scripts/benchmark-romanized.ts",
    "benchmark:romanized:smoke": "LEKH_BENCHMARK_SMOKE=1 LEKH_BENCHMARK_CLI=1 vite-node scripts/benchmark-romanized.ts",
    "benchmark:romanized:full": "npm run benchmark:romanized",
    "benchmark:romanized:self": "LEKH_SCRIPT=benchmark-romanized-self LEKH_BENCHMARK_CLI=1 vite-node scripts/benchmark-romanized-self-consistency.ts",
    "benchmark:romanized:self:smoke": "LEKH_SCRIPT=benchmark-romanized-self LEKH_BENCHMARK_SMOKE=1 LEKH_BENCHMARK_CLI=1 vite-node scripts/benchmark-romanized-self-consistency.ts",
    "benchmark:romanized:self:full": "npm run benchmark:romanized:self",
    "benchmark:protected": "LEKH_BENCHMARK_CLI=1 vite-node scripts/benchmark-protected-spans.ts",
    "benchmark:proofread": "LEKH_BENCHMARK_CLI=1 vite-node scripts/benchmark-proofread.ts",
    "benchmark:competitor": "LEKH_BENCHMARK_CLI=1 vite-node scripts/benchmark-competitor-probes.ts",
    "generate:mixed-span-mutations": "LEKH_SCRIPT=generate-mixed-span-mutations LEKH_BENCHMARK_CLI=1 vite-node scripts/generate-mixed-span-mutation-fixtures.ts",
    "benchmark:mixed-span-mutations": "LEKH_SCRIPT=benchmark-mixed-span-mutations LEKH_BENCHMARK_CLI=1 vite-node scripts/benchmark-mixed-span-mutations.ts",
    "benchmark:typing-session": "LEKH_SCRIPT=benchmark-typing-session LEKH_BENCHMARK_CLI=1 vite-node scripts/benchmark-typing-session.ts",
    "bench:perf": "npm run bench:perf:smoke",
    "bench:perf:smoke": "LEKH_PERF_MODE=smoke vite-node scripts/bench-perf.ts",
    "bench:perf:full": "LEKH_PERF_MODE=full vite-node scripts/bench-perf.ts",
    "scorecard:engine": "LEKH_BENCHMARK_CLI=1 tsx scripts/generate-engine-scorecard.ts",
    "benchmark": "npm run benchmark:fixtures && LEKH_BENCHMARK_CLI=1 vite-node scripts/benchmark-summary.ts && npm run benchmark:typing-session"
  },
  "dependencies": {
    "@nepalibhasha/converter": "^0.1.0",
    "dictionary-ne": "^2.0.0",
    "lucide-react": "^0.468.0",
    "nspell": "^2.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.1.2",
    "jsdom": "^29.1.1",
    "rollup": "npm:@rollup/wasm-node@^4.60.4",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  }
}
