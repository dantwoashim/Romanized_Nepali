{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "resolveJsonModule": true
  },
  "include": ["vite.config.ts", "vitest.config.ts", "scripts/**/*.ts", "src/core/**/*.ts", "src/engine/**/*.ts", "src/**/*.d.ts"],
  "exclude": ["src/**/*.test.ts", "src/tests/**"]
}
